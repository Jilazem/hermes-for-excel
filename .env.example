# ── HermesExcel köprü ayarları ────────────────────────────────────────────
# Kopyalayın: cp .env.example .env  (Windows: copy .env.example .env)

# Köprü sunucusu
PORT=8787
HERMES_BRIDGE_TOKEN=              # boşsa kimlik doğrulama yok; üretimde bir değer verin

# ── Uzak dağıtım (köprü GX10'da, Excel Win11'de) ─────────────────────────
# HERMES_HOST=0.0.0.0            # GX10'da LAN'da dinle (varsayılan 127.0.0.1 = yalnız yerel)
# HERMES_PUBLIC_HOST=gx10.local # Win11'in ulaşacağı ad/IP (sertifika SAN ve manifest URL'leri bununla üretilir)
# HERMES_PUBLIC_PORT=8787
# HERMES_TLS_CERT=./certs/server.crt   # GX10 için özel SAN'lı sertifika (install/configure-remote.mjs üretir)
# HERMES_TLS_KEY=./certs/server.key

# Hermes bağlantısı: gateway | anthropic | mock
HERMES_PROVIDER=mock

# provider=gateway  (Hermes API Server — OpenAI-uyumlu, tam ajan: araçlar+MCP+hafıza)
# Hermes tarafında ~/.hermes/.env içinde etkinleştirin:
#   API_SERVER_ENABLED=true
#   API_SERVER_KEY=<uzun rastgele gizli anahtar>
#   API_SERVER_CORS_ORIGINS=https://localhost:8787
# Sonra `hermes gateway`. Doğrulama: curl http://localhost:8642/v1/health
# (Not: bu köprü TLS'i sonlandırıp anahtarı sunucu tarafında ekler; ayrı Caddy'ye gerek yok.)
HERMES_GATEWAY_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_API_KEY=                  # = API_SERVER_KEY
HERMES_MODEL=hermes-agent

# provider=anthropic  (doğrudan Claude; token'ı hermes-auth-monitor yönetir)
HERMES_ANTHROPIC_URL=https://api.anthropic.com/v1/messages
HERMES_ANTHROPIC_TOKEN=
HERMES_ANTHROPIC_MODEL=claude-opus-4-8

# Fonksiyon önbelleği (hücre tekrar-hesaplamalarında ajanı yormamak için)
HERMES_FN_CACHE_TTL_MS=300000    # 5 dk
HERMES_FN_TIMEOUT_MS=90000       # tek fonksiyon çağrısı üst sınırı

# TLS sertifikaları (office-addin-dev-certs varsayılan konumu otomatik bulunur)
# HERMES_TLS_CERT=./certs/localhost.crt
# HERMES_TLS_KEY=./certs/localhost.key

# ── Yol çevirisi (DOSYA/HISSEDAR): Excel'deki Windows yolunu ajanın gördüğü
#    mount yoluna çevirir. Ajan başka makinede (ör. GX10) ise şart.
# HERMES_PATH_FROM=G:\Drive'ım
# HERMES_PATH_TO=/home/kullanici/WinShare
